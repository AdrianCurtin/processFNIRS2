      {"name":"data", "kind":"required", "type":[["struct"],["char"]]},
      {"name":"N", "kind":"namevalue", "type":["numeric","scalar"], "purpose":"Number of nearest areas"},
      {"name":"MaxDistance", "kind":"namevalue", "type":["numeric","scalar"]}
    ]
  },
  "pf2.probe.montage":
  {
    "inputs":
    [
      {"name":"data", "kind":"required", "type":[["struct"],["char"]]},
      {"name":"Brodmann", "kind":"namevalue", "type":["logical","scalar"]},
      {"name":"MaxDistance", "kind":"namevalue", "type":["numeric","scalar"]},
      {"name":"SavePath", "kind":"namevalue", "type":["char"]}
    ]
  },
  "pf2.probe.saveCfg":
  {
    "inputs":
    [
      {"name":"source", "kind":"required", "type":[["struct"],["char"]]},
      {"name":"savePath", "kind":"required", "type":["char"]},
