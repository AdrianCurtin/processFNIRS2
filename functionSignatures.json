      {"name":"Style", "kind":"namevalue", "type":["choices={'showcase','publication'}"]},
      {"name":"Title", "kind":"namevalue", "type":["char"]},
      {"name":"Colorbar", "kind":"namevalue", "type":["char"]},
      {"name":"savePath", "kind":"namevalue", "type":["char"]}
