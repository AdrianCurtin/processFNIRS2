  {
    "inputs":
    [
      {"name":"data", "kind":"required", "type":[["struct"],["cell"]]},
      {"name":"MaxDistance", "kind":"namevalue", "type":["numeric","scalar"]},
      {"name":"Regions", "kind":"namevalue", "type":["numeric"]},
      {"name":"Space", "kind":"namevalue", "type":["choices={'Brodmann'}"]},
      {"name":"Aggregate", "kind":"namevalue", "type":["choices={'nanmean','mean'}"]}
