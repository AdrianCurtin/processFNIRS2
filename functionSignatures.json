      {"name":"data", "kind":"required", "type":["struct"]},
      {"name":"biomarker", "kind":"required", "type":["choices={'HbO','HbR','HbTotal','HbDiff','CBSI'}"]},
      {"name":"savePath", "kind":"namevalue", "type":["char"]},
      {"name":"View", "kind":"namevalue", "type":["choices={'3d','2d'}"]},
      {"name":"TimeRange", "kind":"namevalue", "type":["numeric"]},
      {"name":"NFrames", "kind":"namevalue", "type":["numeric","scalar"]},
      {"name":"FPS", "kind":"namevalue", "type":["numeric","scalar"]},
      {"name":"Range", "kind":"namevalue", "type":["numeric"]}
